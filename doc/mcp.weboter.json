{
  "mcpServers": {
    "weboter": {
      "command": "python",
      "args": [
        "-m",
        "weboter.mcp.server"
      ],
      "env": {
        "WEBOTER_SERVICE_URL": "http://127.0.0.1:34567",
        "WEBOTER_MCP_PROFILE": "operator",
        "WEBOTER_MCP_TRANSPORT": "stdio",
        "WEBOTER_MCP_CALLER_NAME": "mcp"
      }
    }
  }
}